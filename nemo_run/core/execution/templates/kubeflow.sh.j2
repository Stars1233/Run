#!/bin/bash
#
# Generated by NeMo Run
#
set -evx
export PYTHONUNBUFFERED=1
export TORCHX_MAX_RETRIES={{max_retries}}

{%- for env_var in env_vars %}
{{env_var}}
{%- endfor %}

# Symlink /nemo_run → code_dir so pod-side paths like /nemo_run/scripts/... resolve correctly.
ln -sfn {{code_dir}} /nemo_run

echo "Starting training command..."
set +e

{{training_command}}

exitcode=$?
set -e

echo "Main command exited with code $exitcode"
exit $exitcode
